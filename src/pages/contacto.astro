---
import Layout from '../layouts/Layout.astro';
---
<Layout title="SCD | CONTACTO" activePage="contacto">

  <section class="map-section">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d3864.78!2d-90.5795!3d14.6305!3m2!1i1024!2i768!4f15!3m3!1m2!1s0x0%3A0x0!2s4ta+Calle+B+11-19+Residenciales+Santa+Monica+A+Zona+2+Mixco+Guatemala!5e0!3m2!1sen!2s!4v1"
      width="100%"
      height="400"
      frameborder="0"
      style="border:0; display: block;"
      allowfullscreen
    ></iframe>
  </section>

  <section class="direcciones-section">
    <div class="container">
      <h2 class="section-title">UBICACIÓN</h2>
      <div class="direcciones">
        <p class="direccion">
          <strong>CENTRAL:</strong> 4ta. Calle "B" 11-19 A Residenciales Santa Mónica, Zona 2 de Mixco
        </p>
        <p class="direccion">
          <strong>SEDE:</strong> Edificio CRECE Torre 1 Condado Naranjo, Zona 4 de Mixco
          <span class="nota-referencia">&ldquo;esta solo la ponemos de referencia porque recibimos correspondencia allí todavía&rdquo;</span>
        </p>
      </div>
    </div>
  </section>

  <section class="contact-section">
    <h2 class="contact-heading">contacto</h2>
    <form class="contact-form" action="#" method="POST">
      <div class="form-group">
        <label for="nombre">Nombre <span class="required">*</span></label>
        <input type="text" id="nombre" name="nombre" required />
      </div>
      <div class="form-group">
        <label for="email">Email <span class="required">*</span></label>
        <input type="email" id="email" name="email" required />
      </div>
      <div class="form-group">
        <label for="telefono">Teléfono</label>
        <input type="tel" id="telefono" name="telefono" />
      </div>
      <div class="form-group">
        <label for="mensaje">Mensaje <span class="required">*</span></label>
        <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
      </div>
      <button type="submit" class="submit-btn">Enviar</button>
    </form>
  </section>

</Layout>

<style>
  .map-section {
    width: 100%;
    line-height: 0;
  }

  .contact-section {
    max-width: 600px;
    margin: 60px auto;
    padding: 0 20px;
  }

  .contact-heading {
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    text-align: center;
    color: #323946;
    margin-bottom: 40px;
    letter-spacing: 2px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 13px;
    font-weight: 700;
    color: #323946;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .form-group .required {
    color: #EFBD1A;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px 14px;
    font-family: Roboto, sans-serif;
    font-size: 14px;
    color: #666;
    border: 1px solid #ccc;
    border-radius: 0;
    outline: none;
    transition: border-color 0.3s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #00BFFF;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #999;
  }

  .form-group textarea {
    resize: vertical;
  }

  .submit-btn {
    display: inline-block;
    align-self: flex-start;
    padding: 14px 40px;
    font-family: Roboto, sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #fff;
    background-color: #323946;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s;
  }

  .submit-btn:hover {
    background-color: #00BFFF;
  }

  .direcciones-section {
    padding: 50px 0;
    background: #f4f4f4;
  }

  .direcciones-section .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .direcciones-section .section-title {
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 40px;
    color: #323946;
    text-align: center;
  }

  .direcciones {
    display: flex;
    flex-direction: column;
    gap: 15px;
    align-items: center;
  }

  .direccion {
    font-size: 16px;
    color: #323946;
    margin: 0;
    line-height: 1.5;
    text-align: center;
  }

  .nota-referencia {
    font-size: 13px;
    color: #777;
    font-style: italic;
    display: block;
    margin-top: 4px;
  }

  @media (max-width: 480px) {
    .direcciones-section .section-title {
      font-size: 22px;
    }
    .direccion {
      font-size: 14px;
    }
  }
</style>
