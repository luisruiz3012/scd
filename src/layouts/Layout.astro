---
export interface Props {
  title?: string;
  activePage?: string;
}

const { title = "SCD", activePage = "" } = Astro.props as Props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lykmapipo/icofont@1.0.1/css/icofont.min.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo-link">
          <img src="/images/scd4.jpg" alt="SCD" width="135" height="81" />
        </a>
        <button class="hamburger" aria-label="Menu" data-toggle="nav">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="nav-menu">
          <a href="/" class="nav-link {activePage === 'inicio' ? 'active' : ''}">INICIO</a>
          <a href="/nosotros" class="nav-link {activePage === 'nosotros' ? 'active' : ''}">NOSOTROS</a>
          <a href="/soluciones" class="nav-link {activePage === 'soluciones' ? 'active' : ''}">SOLUCIONES</a>
          <a href="/servicios" class="nav-link {activePage === 'servicios' ? 'active' : ''}">SERVICIOS</a>
          <a href="/contacto" class="nav-link {activePage === 'contacto' ? 'active' : ''}">CONTACTO</a>
        </nav>
        <a href="https://wa.me/50222506216" target="_blank" rel="noopener" class="whatsapp-btn">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-info">
          <div class="footer-item">
            <i class="icofont-location-pin"></i>
            <span>4ta. Calle "B" 11-19 Residenciales santa mónica "A", zona 2 de Mixco.</span>
          </div>
          <div class="footer-item">
            <i class="icofont-envelope"></i>
            <span>info@scd.com.gt</span>
          </div>
        </div>
        <div class="footer-social">
          <a href="https://www.facebook.com/SCD.GT" target="_blank" rel="noopener" class="social-btn"><i class="fab fa-facebook-f"></i></a>
          <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="social-btn"><i class="fab fa-instagram"></i></a>
          <a href="https://twitter.com/" target="_blank" rel="noopener" class="social-btn"><i class="fab fa-twitter"></i></a>
          <a href="https://plus.google.com/discover" target="_blank" rel="noopener" class="social-btn"><i class="fab fa-google-plus-g"></i></a>
        </div>
        <div class="footer-copyright">
          <p>&copy; SCD Todos los derechos reservados | Diseño web por <a href="http://paginaswebparatodos.com/" target="_blank" rel="noopener">paginaswebparatodos.com</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    border: 0;
    box-sizing: border-box;
  }

  html, body {
    overflow-x: hidden;
  }

  body {
    font-family: Roboto, sans-serif;
    font-size: 14px;
    color: #666;
    line-height: 1.6;
  }

  a {
    color: #00BFFF;
    text-decoration: none;
  }

  a:hover {
    color: #EFBD1A;
  }

  a, p, h1, h2, h3, h4, h5, h6, .Button, img, .submit-btn {
    transition: 0.6s;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .clearfix::after {
    content: "";
    display: table;
    clear: both;
  }

  .site-header {
    background-color: #323946;
    padding: 10px 0;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
  }

  .logo-link {
    flex-shrink: 0;
    line-height: 0;
  }

  .logo-link img {
    display: block;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: #25D366;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 8px 16px;
    border-radius: 5px;
    white-space: nowrap;
    margin-left: auto;
  }

  .whatsapp-btn:hover {
    background-color: #128C7E;
    color: #fff;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 3px;
    background: #fff;
    border-radius: 2px;
  }

  .nav-menu {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .nav-link {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 10px 15px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .nav-link:hover {
    color: #EFBD1A;
  }

  .nav-link.active {
    color: #EFBD1A;
    border-bottom: 2px solid #00BFFF;
  }

  main {
    min-height: 400px;
  }

  .site-footer {
    background-color: #323946;
    padding: 40px 0 20px;
    color: #f4f4f4;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }

  .footer-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    line-height: 1.5;
  }

  .footer-item i {
    color: #EFBD1A;
    font-size: 16px;
  }

  .footer-item span {
    color: #fff;
  }

  .footer-social {
    display: flex;
    gap: 10px;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid #fff;
    color: #00BFFF;
    font-size: 15px;
    transition: 0.5s;
  }

  .social-btn:hover {
    background-color: #EFBD1A;
    border-color: transparent;
    color: #fff;
  }

  .footer-copyright p {
    font-size: 11px;
    color: #f4f4f4;
    line-height: 1.4;
  }

  .footer-copyright a {
    color: #fff;
  }

  .footer-copyright a:hover {
    color: #DBDBDB;
  }

  @media (max-width: 768px) {
    .header-inner {
      gap: 15px;
    }

    .whatsapp-btn {
      margin-left: 0;
      font-size: 12px;
      padding: 6px 12px;
    }

    .hamburger {
      display: flex;
      margin-left: auto;
    }

    .hamburger.active + .nav-menu,
    .nav-menu.open {
      display: flex;
    }

    .nav-menu {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 0;
      order: 2;
    }

    .nav-link {
      padding: 12px 15px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    .logo-link img {
      width: 100px;
      height: auto;
    }
  }

  @media (min-width: 769px) {
    .hamburger {
      display: none;
    }

    .nav-menu {
      display: flex !important;
    }
  }

  @media (max-width: 480px) {
    .header-inner {
      padding: 0 10px;
      gap: 10px;
    }

    .footer-inner {
      padding: 0 10px;
    }

    .footer-item {
      font-size: 11px;
    }

    .social-btn {
      width: 32px;
      height: 32px;
      font-size: 13px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('[data-toggle="nav"]');
    const nav = document.querySelector('.nav-menu');
    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('active');
        nav.classList.toggle('open');
      });
    }
  });
</script>
